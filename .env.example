# ============================================================
# AI Math Lesson Assistant — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Neon Postgres ---
# Get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# --- Neon Auth ---
# Enable Auth in Neon Console → Project → Branch → Auth → Configuration
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=your-secret-at-least-32-characters-long

# --- Supabase Storage (file uploads only, NOT auth) ---
# Get from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (for GPT-4 analysis & homework generation) ---
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# --- Anthropic (alternative for analysis — set USE_ANTHROPIC=true) ---
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
USE_ANTHROPIC=false

# --- Deepgram (for transcription) ---
# Get from https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Recall.ai (live lesson meeting bot) ---
# Get from https://recall.ai → Dashboard → API Keys
RECALL_API_KEY=your-recall-api-key
# Optional: verify webhook signatures
RECALL_WEBHOOK_SECRET=

# --- Pipeline API Secret (protects internal API routes) ---
PIPELINE_API_SECRET=generate-a-random-secret-here
